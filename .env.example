NODE_ENV=production
VIBESTACK_HOST=vibestack.example.com
VIBESTACK_PUBLIC_URL=https://vibestack.example.com
VIBESTACK_BASE_DOMAIN=apps.example.com
VIBESTACK_COOKIE_DOMAIN=example.com
VIBESTACK_INSTALL_DIR=/opt/vibestack
VIBESTACK_SOURCE_DIR=/opt/vibestack-source
VIBESTACK_REPO_URL=https://github.com/dankritz/vibestack.git
VIBESTACK_UPDATE_CHANNEL=main
VIBESTACK_DATA_DIR=/var/lib/vibestack
VIBESTACK_SESSION_SECRET=replace-with-generated-secret
VIBESTACK_SECRET_KEY=replace-with-generated-secret
DATABASE_URL=postgres://vibestack:replace-with-generated-password@postgres:5432/vibestack
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=vibestack
POSTGRES_PASSWORD=replace-with-generated-password
POSTGRES_DB=vibestack
REDIS_URL=redis://redis:6379
TRAEFIK_NETWORK=vibestack_apps
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_IMAGE=traefik:v3
TRAEFIK_DASHBOARD_HOST=traefik.example.com
LETSENCRYPT_EMAIL=admin@example.com
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=replace-with-strong-password
RUNTIME_DRIVER=docker
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_ZONE_ID=replace-with-cloudflare-zone-id
CLOUDFLARE_TARGET_HOSTNAME=vibestack.example.com
